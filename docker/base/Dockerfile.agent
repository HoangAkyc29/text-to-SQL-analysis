# syntax=docker/dockerfile:1
# Extends project-base with platform-core + HTTP/LLM stack. Image: abstract-base/agent-base:local
# TODO: rebuild when docker-agent group changes
ARG PROJECT_BASE=abstract-base/project-base:local
FROM ${PROJECT_BASE}
WORKDIR /app
COPY . /app
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --only-group docker-agent --no-dev
