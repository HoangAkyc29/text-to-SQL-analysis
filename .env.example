# OpenRouter (LLM — optional for stub agents)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Profile from config/models.yaml
MODEL_PROFILE=openrouter_default

# Paths
AGENT_ROOT_DIR=.
AGENT_DATA_DIR=./data
TRADING_CONFIG=config/trading.yaml

# Platform transport: in_process (local) | http (Docker A2A)
PLATFORM_TRANSPORT=in_process

# MCP server URL (Docker / remote). Unset for local stdio subprocesses.
# BASE_MCP_SERVER_URL=http://localhost:8100/sse

# Agent HTTP endpoint (Docker A2A). Unset for in-process graph runs.
# BASE_AGENT_URL=http://localhost:8200

LOG_LEVEL=INFO
